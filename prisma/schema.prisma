// Peelie 백엔드 스키마 첫 컷
// 결정 사항:
//  - PK: cuid 단일 (publicId 분리 X)
//  - PersonalityType: enum 6개 고정 (코드값은 사용자가 정의해서 교체)
//  - 친구 관계: 단방향 (FriendCode 입력 → 즉시 추가)
//  - Schedule 등록 즉시 ChatRoom 생성
//  - RefreshToken / Embedding / PushToken / Notification 은 챗봇·Auth·FCM 붙일 때 추가

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// Enums
// ============================================================

// 6개 고정. UI 표시명/태그/시스템 프롬프트는 src/llm/prompts/personalities.ts 에 별도 매핑 (챗봇 단계)
enum PersonalityType {
  STRAIGHT_SHOOTER    // 직진 본능파
  ENERGETIC_TALKER    // 불꽃토커
  QUIET_CHARMER       // 조용한호감캐
  ANALYTICAL_OBSERVER // 뇌풀가동 분석파
  HEART_COLLECTOR     // 속마음 수집가
  STAGE_SETTER        // 판깔기 전문가
}

enum AuthProvider {
  KAKAO
  APPLE
}

enum MessageRole {
  USER
  AVATAR
}

// ============================================================
// User / Account
// ============================================================

model User {
  id          String          @id @default(cuid())
  email       String?         @unique
  name        String
  personality PersonalityType
  friendCode  String          @unique
  // soft delete 마커. null 이면 활성 사용자. 탈퇴 시 NOW() + friendCode 에 __deleted__{ts} suffix.
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts            Account[]
  avatar              Avatar?
  refreshTokens       RefreshToken[]
  friendshipsAsOwner  Friendship[] @relation("FriendshipOwner")
  friendshipsAsFriend Friendship[] @relation("FriendshipFriend")
  schedulesAsOwner    Schedule[]   @relation("ScheduleOwner")
  schedulesAsFriend   Schedule[]   @relation("ScheduleFriend")
}

model Account {
  id             String       @id @default(cuid())
  userId         String
  provider       AuthProvider
  providerUserId String
  // provider 의 refresh token (Apple 만 사용 — 회원탈뢰 시 revoke 호출용).
  // 카카오는 사용 안 함. 첫 가입 시점에만 받을 수 있어서 신규 가입 흐름에서 저장.
  refreshToken   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

// access token 은 stateless JWT. refresh token 만 DB 저장 (hash 형태, raw X)
// 14일 TTL, revocable, rotation 으로 재발급
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// Avatar (LLM 페르소나 거점)
// 첫 컷은 비어있음. 챗봇 단계에서 systemPrompt/memory 등 컬럼 추가
// ============================================================

model Avatar {
  id     String @id @default(cuid())
  userId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// Friendship (단방향)
// owner 가 friend 의 FriendCode 를 입력 → row 1개 생성
// ============================================================

model Friendship {
  id           String @id @default(cuid())
  ownerId      String
  friendUserId String

  createdAt DateTime @default(now())

  owner      User @relation("FriendshipOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friendUser User @relation("FriendshipFriend", fields: [friendUserId], references: [id], onDelete: Cascade)

  @@unique([ownerId, friendUserId])
  @@index([friendUserId])
}

// ============================================================
// Schedule + ChatRoom (1:1)
// 일정 등록 트랜잭션에서 ChatRoom 같이 INSERT
// ============================================================

model Schedule {
  id           String   @id @default(cuid())
  ownerId      String
  friendUserId String
  meetDate     DateTime @db.Date
  description  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User      @relation("ScheduleOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  friendUser User      @relation("ScheduleFriend", fields: [friendUserId], references: [id], onDelete: Cascade)
  chatRoom   ChatRoom?

  @@index([ownerId, meetDate])
  @@index([friendUserId])
}

model ChatRoom {
  id            String    @id @default(cuid())
  scheduleId    String    @unique
  // 마지막으로 사용자가 채팅방에 진입한 시각. 선제 인사 노출 여부 판단용.
  lastEnteredAt DateTime?
  // 마지막으로 사용자가 "읽음" 처리한 시각.
  // 채팅방 진입 부수효과 또는 명시적 /read 호출로 갱신.
  // isUnread = (lastMessageAt > lastReadAt) 판단용.
  lastReadAt    DateTime?

  createdAt DateTime @default(now())

  schedule Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  messages Message[]
}

// ============================================================
// Message (turn 단위)
//  - 1 LLM 응답 = 1 row
//  - bubbles: [{ text, delayMs }]  ← 멀티 버블
//  - suggestions: assistant 응답일 때 3개 (USER 메시지는 빈 배열)
// ============================================================

model Message {
  id          String      @id @default(cuid())
  chatRoomId  String
  role        MessageRole
  bubbles     Json
  suggestions String[]    @default([])

  createdAt DateTime @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@index([chatRoomId, createdAt])
}
